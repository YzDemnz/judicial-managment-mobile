{
  "expo": {
    "name": "Judicial Managment",
    "slug": "judicial-managment-mobile",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "judicialmanagmentmobile",
    "userInterfaceStyle": "automatic",
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#d4ab4e",
          "defaultChannel": "audiencias"
        }
      ],
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 190,
          "resizeMode": "contain",
          "backgroundColor": "#0c1424",
          "dark": {
            "image": "./assets/splash-icon.png",
            "backgroundColor": "#0c1424"
          }
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mrlegal.judicialmanagment.mobile",
      "buildNumber": "2"
    },
    "android": {
      "package": "com.mrlegal.judicialmanagment.mobile",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#0c1424",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "releaseNotes": [
        "Actualizaciones automaticas disponibles desde Configuracion.",
        "Nuevo icono oficial de Judicial Managment en Android.",
        "Mejoras en la identidad visual de inicio y notificaciones."
      ]
    }
  }
}
